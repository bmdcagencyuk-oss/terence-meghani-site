# Required for contact form email delivery (server-side)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
CONTACT_FORM_TO=hello@terencemeghani.com

# Public — baked into client bundle at build time
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=terencemeghani.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dmdp4f2wp

# Optional — site base URL for sitemap / OG
NEXT_PUBLIC_SITE_URL=https://terencemeghani.com

# Notes section feature flag. When "true", the Notes link appears in the
# top nav, the mobile menu's Notes row renders, and the "Latest: Twelve
# years in →" live-indicator entry is included in the rotation. Defaults
# to false (any value other than the literal string "true") so /notes
# routes remain reachable by direct URL but stay unlinked from the site.
NEXT_PUBLIC_NOTES_VISIBLE=false

# Lead pipeline — used by `npm run scrape` and the open-tracking /
# unsubscribe API routes. Sheet column layout is configured in
# scripts/scrape-leads.mjs (COLUMNS) and app/api/_lib/sheets-client.js (COL).
COMPANIES_HOUSE_API_KEY=
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_PRIVATE_KEY=
GOOGLE_SHEETS_SPREADSHEET_ID=
SIGNING_SECRET=
LEADS_SHEET_NAME=Leads
# YYYY-MM-DD; default = 2 years before today
LEADS_INCORPORATED_FROM=
LEADS_LIMIT=200

# `npm run send` — cold email pipeline
# Default: "Terence Meghani <hello@terencemeghani.com>" (must be a verified
# Resend domain). LEADS_SEND_LIMIT caps each run; LEADS_SEND_DELAY_MS spaces
# Resend calls so we stay well under daily quotas.
LEADS_FROM_EMAIL=
LEADS_SEND_LIMIT=30
LEADS_SEND_DELAY_MS=2000

# `npm run enrich` — finds website + email for leads with empty EMAIL.
# Free, best-effort (DuckDuckGo + page scrape). DELAY_MS gates DDG calls
# so we don't trip rate limits.
LEADS_ENRICH_LIMIT=30
LEADS_ENRICH_DELAY_MS=3000
