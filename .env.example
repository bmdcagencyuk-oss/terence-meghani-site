# Required for contact form email delivery (server-side)
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxxx
CONTACT_FORM_TO=hello@terencemeghani.com

# Public — baked into client bundle at build time
NEXT_PUBLIC_PLAUSIBLE_DOMAIN=terencemeghani.com
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=dmdp4f2wp

# Optional — site base URL for sitemap / OG
NEXT_PUBLIC_SITE_URL=https://terencemeghani.com

# Notes section feature flag. When "true", the Notes link appears in the
# top nav, the mobile menu's Notes row renders, and the "Latest: Twelve
# years in →" live-indicator entry is included in the rotation. Defaults
# to false (any value other than the literal string "true") so /notes
# routes remain reachable by direct URL but stay unlinked from the site.
NEXT_PUBLIC_NOTES_VISIBLE=false
